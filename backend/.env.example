# ─────────────────────────────────────────────────────────────────────────────
# ResumePilot Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_a_strong_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── Database ─────────────────────────────────────────────────────────────────
# Local PostgreSQL (development):
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/resumepilot
#
# Neon serverless PostgreSQL (staging / production):
# Copy the connection string from your Neon project dashboard → Connection Details → Direct.
# Format: postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/resumepilot

# ── CORS ─────────────────────────────────────────────────────────────────────
# Required in production — set to your deployed backend domain.
# Comma-separated list of allowed origins.
# In production this MUST be set — the config.py defaults are localhost-only.
# Example: BACKEND_CORS_ORIGINS=https://api.resumepilot.app,https://resumepilot.app
BACKEND_CORS_ORIGINS=

# ── Cloudinary file storage ───────────────────────────────────────────────────
# Optional but recommended. When set, uploaded resume files (PDF/DOCX) are stored
# in Cloudinary and a permanent download URL is saved to the resume row.
# Get these from: https://console.cloudinary.com → Dashboard
# If not set, the app still works — files are processed in memory only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────
# PROJECT_NAME=Resume Pilot API
# API_V1_STR=/api/v1
