# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# =============================================================================
# Editor / IDE
# =============================================================================

# VS Code — keep launch and extension configs, ignore personal settings
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# JetBrains / Android Studio
.idea/
*.iml
*.ipr
*.iws
*.suo
*.ntvs*
*.njsproj
*.sln

# Vim / Emacs swap files
*.sw?
*.swp
*~


# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*


# =============================================================================
# Python / FastAPI backend
# =============================================================================

# Bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments (all common names)
myenv/
venv/
.venv/
env/
.env_local/

# Environment variables — never commit secrets
.env
backend/.env
# .env.example is intentionally committed

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
MANIFEST
wheels/

# mypy / pyright type checking cache
.mypy_cache/
.pyright/

# Alembic auto-generated (keep handwritten migrations, ignore pycache inside)
backend/alembic/__pycache__/
backend/alembic/versions/__pycache__/


# =============================================================================
# User-uploaded files (backend file storage)
# =============================================================================
uploads/*
!uploads/README.md
backend/uploads/*
!backend/uploads/README.md


# =============================================================================
# Flutter / Dart
# =============================================================================

# Dart tool cache and package config
.dart_tool/
.packages
.pub-cache/
.pub/

# Flutter plugin lists (auto-generated on `flutter pub get`)
.flutter-plugins
.flutter-plugins-dependencies

# Build outputs
build/
/coverage/

# Obfuscation / symbolication maps
app.*.symbols
app.*.map.json

# Generated code — uncomment if you use build_runner and commit generated files
# *.g.dart
# *.freezed.dart

# IDE project files
*.iml

# Android Gradle wrapper outputs
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/

# Android local machine paths
android/local.properties
android/key.properties
*.jks

# iOS build artifacts
ios/Flutter/.last_build_id
ios/Pods/
ios/.symlinks/

# macOS build artifacts
macos/Flutter/GeneratedPluginRegistrant.swift

# Windows build artifacts
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# Web build artifacts
web/flutter_service_worker.js
# BDApps API Scripts
bdapps_api/
